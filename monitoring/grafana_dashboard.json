      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_scans_total{service=\"scanner\"}[5m])", "legendFormat": "Scanner", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_scans_total{service=\"simulator\"}[5m])", "legendFormat": "Simulator", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_scans_total{service=\"validator\"}[5m])", "legendFormat": "Validator", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
