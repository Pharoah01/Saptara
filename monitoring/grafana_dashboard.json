      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_tests_total{status=\"passed\"}[5m])", "legendFormat": "Passed", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_tests_total{status=\"failed\"}[5m])", "legendFormat": "Failed", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_tests_total{status=\"vulnerable\"}[5m])", "legendFormat": "Vulnerable", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(saptara_tests_total{status=\"blocked\"}[5m])", "legendFormat": "Blocked", "refId": "D" }
      ]
    },
