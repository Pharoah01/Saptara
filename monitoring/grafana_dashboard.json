        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"orchestrator\"}", "legendFormat": "Orchestrator", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"scanner\"}", "legendFormat": "Scanner", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"simulator\"}", "legendFormat": "Simulator", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"validator\"}", "legendFormat": "Validator", "refId": "D" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
