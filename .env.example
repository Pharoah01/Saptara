# Security Testing Suite Environment Configuration

# Service Configuration
LOG_LEVEL=INFO
SERVICE_NAME=security-test
DEBUG=false

# Database Configuration
DATABASE_URL=postgresql://security_user:security_pass@localhost:5432/security_test
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# Security Configuration
MAX_CONCURRENT_SCANS=10
DEFAULT_TIMEOUT=30
RATE_LIMIT_PER_SECOND=10
MAX_PAYLOAD_SIZE=1048576  # 1MB

# Authentication (if enabled)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys (for external services)
EXTERNAL_API_KEY=
WEBHOOK_SECRET=

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
METRICS_RETENTION_DAYS=30

# Logging Configuration
LOG_FILE_PATH=/var/log/security-test/app.log
LOG_ROTATION_SIZE=10MB
LOG_RETENTION_DAYS=7

# Service URLs (for inter-service communication)
ORCHESTRATOR_URL=http://localhost:8000
SCANNER_URL=http://localhost:8001
VALIDATOR_URL=http://localhost:8002
SIMULATOR_URL=http://localhost:8003

# Docker Configuration
COMPOSE_PROJECT_NAME=security-test
DOCKER_REGISTRY=
DOCKER_TAG=latest

# Development Configuration
RELOAD=false
WORKERS=1
HOST=0.0.0.0

# Security Headers
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=["json", "xml", "csv", "txt"]

# Notification Configuration
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/var/backups/security-test

# Performance Configuration
ASYNC_POOL_SIZE=100
CONNECTION_TIMEOUT=30
READ_TIMEOUT=30
WRITE_TIMEOUT=30

# Feature Flags
FEATURE_ADVANCED_SCANNING=true
FEATURE_MACHINE_LEARNING=false
FEATURE_CUSTOM_PAYLOADS=true
FEATURE_REPORTING=true

# Third-party Integrations
JIRA_ENABLED=false
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

GITHUB_ENABLED=false
GITHUB_TOKEN=
GITHUB_REPO=

# Compliance and Audit
AUDIT_LOGGING=true
COMPLIANCE_MODE=false
DATA_RETENTION_DAYS=90
ANONYMIZE_RESULTS=false